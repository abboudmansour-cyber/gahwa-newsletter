/**
 * replay-engine.js — Git-Driven Replay Engine (Upgraded)
 *
 * Replaces the previous log-based replay with Git-driven replay from execution state.
 *
 * BEHAVIOR:
 *   1. Read execution-state.json to find the last FAILED step
 *   2. git checkout <gitCommitBeforeStep> to reset to pre-step state
 *   3. Re-run ONLY the failed step
 *   4. Re-commit with traceable message
 *   5. Update execution-state.json
 *
 * Git = Source of Truth for execution history.
 * Every replay is a new state transition rooted in the original git state.
 *
 * @module replay-engine
 */

import { spawn } from "child_process";
import path from "path";
import fs from "fs";
import { fileURLToPath } from "url";
import { execSync } from "child_process";
import { ensureExecutionContext } from "./runtime.js";
import {
  getEligibleReplays,
  getEntry,
  incrementReplayAttempt,
  markAsReplayed,
  markFailedReplay,
  getPendingReplayCount,
} from "./recovery.js";
import {
  acquireLock,
  releaseLock,
  MODES,
  printModeBanner,
} from "./state.js";
import {
  snapshotBefore,
  snapshotAfter,
  computeDiff,
  autoCommit,
  checkoutCommit,
  checkoutOriginal,
} from "./git-snapshot.js";
import {
  findLastFailedStep,
  getCommitBeforeStep,
  prepareReplayWorkspace,
  getRunState,
} from "./git-state-machine.js";

// ── Bootstrap execution context ────────────────────────────────────────────
ensureExecutionContext();

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const OPERATOR_JS = path.join(__dirname, "..", "operator.js");
const ROOT = path.resolve(__dirname, "..", "..");
const STATE_FILE = path.join(__dirname, "..", "logs", "execution-state.json");

// ── CONSTANTS ──────────────────────────────────────────────────────────────
const MAX_REPLAYS_PER_RUN = 5;
const REPLAY_TIMEOUT_MS = 120_000; // 2 minutes per replay before timeout

// ── Execution State Helpers ────────────────────────────────────────────────

function readExecutionState() {
  try {
    if (!fs.existsSync(STATE_FILE)) return null;
    return JSON.parse(fs.readFileSync(STATE_FILE, "utf-8"));
  } catch {
    return null;
  }
}

function writeExecutionState(state) {
  try {
    fs.mkdirSync(path.dirname(STATE_FILE), { recursive: true });
    fs.writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), "utf-8");
  } catch (err) {
    console.error(`[REPLAY-ENGINE] ❌ Failed to write execution state: ${err.message}`);
  }
}

// ── Git-Driven Replay Logic ────────────────────────────────────────────────

/**
 * Find the last FAILED step in an execution-state.json.
 *
 * @param {object} state - The execution state
 * @returns {object|null} { step: object, index: number } or null if none
 */
function findLastFailedStep(state) {
  if (!state || !state.steps || state.steps.length === 0) return null;

  // Search in reverse for the first FAILED step
  for (let i = state.steps.length - 1; i >= 0; i--) {
    if (state.steps[i].status === "FAILED") {
      return { step: state.steps[i], index: i };
    }
  }

  // Check for PARTIAL statuses that indicate incomplete execution
  for (let i = state.steps.length - 1; i >= 0; i--) {
    if (state.steps[i].status === "PARTIAL") {
      return { step: state.steps[i], index: i };
    }
  }

  return null;
}

/**
 * Find the git commit hash BEFORE a specific step index.
 * This is the commit state the system was in before the step ran.
 *
 * @param {object} state - The execution state
 * @param {number} stepIndex - The step index
 * @returns {string|null} The git commit hash to reset to
 */
function findGitCommitBeforeStep(state, stepIndex) {
  if (!state) return null;

  // The commit BEFORE this step is:
  // - If stepIndex > 0: the commit AFTER the previous step
  // - If stepIndex === 0: state.gitCommitBefore (initial state)
  if (stepIndex > 0 && state.steps[stepIndex - 1]) {
    // The previous step's commit is stored in gitCommitAfter after that step ran
    // But we need to find it — it may have been committed via autoCommit
    // The safest approach: use git to find the commit by message
    const prevStep = state.steps[stepIndex - 1];
    const prevStepName = prevStep.step;

    try {
      // Find the commit that matches "exec: <prevStepName>" pattern
      const logOutput = execSync(
        `git log --oneline --grep="exec: ${prevStepName}" --max-count=1`,
        { encoding: "utf-8", cwd: ROOT, timeout: 5000 }
      ).trim();

      if (logOutput) {
        const hash = logOutput.split(" ")[0];
        if (hash) return hash;
      }
    } catch {
      // Fall through
    }

    // Fallback: use the hash from the previous step's commit if stored
    // We can try the state.gitCommitAfter
    if (state.steps[stepIndex - 1].commitHash) {
      return state.steps[stepIndex - 1].commitHash;
    }
  }

  // Default: use the initial gitCommitBefore from the state
  return state.gitCommitBefore || null;
}

/**
 * Perform a Git-driven replay of a failed step.
 *
 * 1. Read execution-state.json
 * 2. Find the last FAILED step
 * 3. git checkout <gitCommitBeforeStep> to reset state
 * 4. Spawn operator.js --replay for the failed run
 * 5. Re-commit and update state
 *
 * @param {object} recoveryEntry - The recovery index entry
 * @param {number} attemptCount - Current replay attempt
 * @returns {Promise<boolean>} Whether the replay succeeded
 */
async function replayStepFromGit(recoveryEntry, attemptCount) {
  const runId = recoveryEntry.runId;

  console.log(`\n🔄 [GIT-REPLAY] Preparing git-driven replay for: ${runId}`);

  // ── Step 1: Read fresh execution state ────────────────────────────────
  const state = readExecutionState();
  if (!state) {
    console.log(`   ❌ No execution state found — cannot perform git-driven replay`);
    return false;
  }

  // ── Step 2: Find the failed step ─────────────────────────────────────
  const failedInfo = findLastFailedStep(state);
  if (!failedInfo) {
    console.log(`   ❌ No failed step found in execution state — falling back to full replay`);
    // Fall back to full operator.js --replay
    return spawnReplayWithTimeout(recoveryEntry, attemptCount);
  }

  const { step: failedStep, index: stepIndex } = failedInfo;
  console.log(`   📋 Failed step: "${failedStep.step}" (index ${stepIndex})`);
  console.log(`   Status: ${failedStep.status}`);
  if (failedStep.error) {
    console.log(`   Error: ${failedStep.error}`);
  }

  // ── Step 3: Git reset to pre-failed-step state ───────────────────────
  const targetCommit = findGitCommitBeforeStep(state, stepIndex);
  const currentBranch = getCurrentBranch();

  if (!targetCommit) {
    console.log(`   ❌ Cannot determine target commit for step "${failedStep.step}" — falling back`);
    return spawnReplayWithTimeout(recoveryEntry, attemptCount);
  }

  // Verify the target commit exists
  if (!commitExists(targetCommit)) {
    console.log(`   ❌ Target commit ${targetCommit.substring(0, 12)}... does not exist — falling back`);
    return spawnReplayWithTimeout(recoveryEntry, attemptCount);
  }

  console.log(`   🎯 Target commit for reset: ${targetCommit.substring(0, 12)}...`);
  console.log(`   Current branch: ${currentBranch}`);

  // Save current branch before checkout
  const savedBranch = currentBranch;

  // ── Step 4: Checkout pre-step state ──────────────────────────────────
  const checkoutOk = checkoutCommit(targetCommit);
  if (!checkoutOk) {
    console.log(`   ❌ Failed to checkout ${targetCommit.substring(0, 12)}... — falling back`);
    return spawnReplayWithTimeout(recoveryEntry, attemptCount);
  }

  // ── Step 5: Spawn operator.js --replay for the failed run ────────────
  console.log(`   🚀 Spawning: node operator.js ${recoveryEntry.job || "daily-newsletter"} --replay`);
  console.log(`   (Running from git state: ${targetCommit.substring(0, 12)}...)`);

  const replaySuccess = await new Promise((resolve) => {
    const childArgs = [OPERATOR_JS, recoveryEntry.job || "daily-newsletter", "--replay"];

    const child = spawn("node", childArgs, {
      cwd: ROOT,
      stdio: "inherit",
      env: {
        ...process.env,
        RUN_ID: `replay-${runId}-v${attemptCount}`,
        REPLAY_SOURCE: runId,
        REPLAY_ATTEMPT: String(attemptCount),
        REPLAY_GIT_RESET: targetCommit,
      },
      shell: false,
    });

    const timer = setTimeout(() => {
      console.log(`   ⏰ REPLAY TIMEOUT — ${runId} exceeded ${REPLAY_TIMEOUT_MS / 1000}s`);
      child.kill("SIGTERM");
      resolve(false);
    }, REPLAY_TIMEOUT_MS);

    child.on("error", (err) => {
      clearTimeout(timer);
      console.log(`   ❌ Spawn error: ${err.message}`);
      resolve(false);
    });

    child.on("exit", (code, signal) => {
      clearTimeout(timer);
      resolve(code === 0);
    });
  });

  // ── Step 6: Return to original branch ─────────────────────────────────
  checkoutOriginal(savedBranch);

  // ── Step 7: Update execution state with replay result ────────────────
  if (replaySuccess) {
    const newState = readExecutionState();
    if (newState) {
      // Mark the previously failed step as RECOVERED
      for (const step of newState.steps) {
        if (step.step === failedStep.step && step.status === "SUCCESS") {
          step.status = "RECOVERED";
          step.error = `Recovered via git-driven replay (v${attemptCount})`;
        }
      }
      writeExecutionState(newState);
    }
  }

  return replaySuccess;
}

// ── REPLAY EXECUTION ───────────────────────────────────────────────────────

/**
 * Run the replay engine.
 *
 * 1. Reads recovery-index.json
 * 2. Filters replayEligible: true entries
 * 3. For each entry, attempts git-driven step replay first
 * 4. Falls back to full operator.js --replay if git-driven fails
 * 5. Updates recovery index on success/failure
 *
 * @returns {Promise<{replayed: number, succeeded: number, failed: number, pending: number}>}
 */
export async function runReplayEngine(runId = null) {
  // ── LOOP ISOLATION: Acquire REPLAY lock ─────────────────────────────
  // SINGLE IDENTITY: Use the provided runId from the caller.
  // If called from executor.js's scanAndIndexFailures, the currentRunId
  // is passed through. Standalone execution uses a simple label since
  // the lock ID is only for mutual exclusion, not execution identity.
  const replayLockId = runId || `replay-cycle`;

  if (!acquireLock(MODES.REPLAY, replayLockId)) {
    console.log("⛔ [REPLAY-ENGINE] Cannot acquire REPLAY lock — another mode is active. Aborting replay cycle.");
    return { replayed: 0, succeeded: 0, failed: 0, pending: getPendingReplayCount() };
  }

  printModeBanner(MODES.REPLAY, `cycle ${replayLockId}`);


  try {
    const pending = getEligibleReplays();

    if (pending.length === 0) {
      console.log("[REPLAY-ENGINE] No eligible replays found — nothing to do");
      return { replayed: 0, succeeded: 0, failed: 0, pending: 0 };
    }

    console.log("\n═══════════════════════════════════════════════");
    console.log("🔄 REPLAY ENGINE STARTED (Git-Driven)");
    console.log(`   Pending replays: ${pending.length}`);
    console.log(`   Max per cycle:   ${MAX_REPLAYS_PER_RUN}`);
    console.log("═══════════════════════════════════════════════\n");

    // Process up to MAX_REPLAYS_PER_RUN entries per cycle
    const batch = pending.slice(0, MAX_REPLAYS_PER_RUN);
    let succeeded = 0;
    let failed = 0;

    for (const entry of batch) {
      console.log(`\n───────────────────────────────────────────────`);
      console.log(`🔄 Replaying run: ${entry.runId}`);
      console.log(`   Job:    ${entry.job}`);
      console.log(`   Date:   ${entry.date}`);
      console.log(`   Status: ${entry.status}`);
      console.log(`   Reason: ${entry.reason}`);
      if (entry.commit && entry.commit !== "unknown") {
        console.log(`   Commit: ${entry.commit}`);
      }

      // ── REPLAY LOOP GUARD: increment attempt counter BEFORE execution ──
      const attemptCount = incrementReplayAttempt(entry.runId);

      // Check if guard already tripped (attempt > 2)
      const currentEntry = getEntry(entry.runId);
      if (!currentEntry || !currentEntry.replayEligible) {
        console.log(`   ⛔ Replay loop guard active — ${entry.runId} exceeded max attempts`);
        failed++;
        continue;
      }

      // ── Try Git-driven replay first ──────────────────────────────────
      console.log(`   🔍 Attempting git-driven step replay...`);
      let success = await replayStepFromGit(entry, attemptCount);

      // ── Fall back to full operator.js --replay ───────────────────────
      if (!success) {
        console.log(`   ⏩ Falling back to full operator.js --replay...`);
        success = await spawnReplayWithTimeout(entry, attemptCount);
      }

      if (success) {
        markAsReplayed(entry.runId);
        succeeded++;
        console.log(`   ✅ REPLAY SUCCEEDED — ${entry.runId}`);
      } else {
        markFailedReplay(entry.runId, `Replay attempt ${attemptCount} failed`);
        failed++;
        console.log(`   ❌ REPLAY FAILED — ${entry.runId}`);
      }
    }

    const remaining = getPendingReplayCount();

    console.log("\n═══════════════════════════════════════════════");
    console.log("📊 REPLAY ENGINE SUMMARY");
    console.log(`   Replayed:  ${batch.length}`);
    console.log(`   Succeeded: ${succeeded}`);
    console.log(`   Failed:    ${failed}`);
    console.log(`   Remaining: ${remaining}`);
    console.log("═══════════════════════════════════════════════\n");

    return { replayed: batch.length, succeeded, failed, pending: remaining };
  } finally {
    releaseLock();
  }
}

/**
 * Spawn operator.js with --replay flag and wait for completion.
 * Uses a timeout to prevent runaway processes.
 *
 * @param {object} entry - The recovery index entry
 * @param {number} attemptCount - Current replay attempt number
 * @returns {Promise<boolean>} Whether the replay succeeded
 */
function spawnReplayWithTimeout(entry, attemptCount) {
  return new Promise((resolve) => {
    const childArgs = [OPERATOR_JS, entry.job || "daily-newsletter", "--replay"];

    console.log(`   🚀 Spawning: node operator.js ${entry.job} --replay`);

    const child = spawn("node", childArgs, {
      cwd: ROOT,
      stdio: "inherit",
      env: {
        ...process.env,
        RUN_ID: `replay-${entry.runId}-v${attemptCount}`,
        REPLAY_SOURCE: entry.runId,
        REPLAY_ATTEMPT: String(attemptCount),
      },
      shell: false,
    });

    const timer = setTimeout(() => {
      console.log(`   ⏰ REPLAY TIMEOUT — ${entry.runId} exceeded ${REPLAY_TIMEOUT_MS / 1000}s`);
      child.kill("SIGTERM");
      resolve(false);
    }, REPLAY_TIMEOUT_MS);

    child.on("error", (err) => {
      clearTimeout(timer);
      console.log(`   ❌ Failed to spawn: ${err.message}`);
      resolve(false);
    });

    child.on("exit", (code, signal) => {
      clearTimeout(timer);
      if (code === 0) {
        resolve(true);
      } else if (signal) {
        console.log(`   ❌ Killed with signal ${signal}`);
        resolve(false);
      } else {
        console.log(`   ❌ Exited with code ${code}`);
        resolve(false);
      }
    });
  });
}

/**
 * Enqueue a specific run for replay by adding it to the recovery index
 * and then triggering the replay engine immediately.
 *
 * @param {string} runId - The failed run ID
 * @param {string} job - The job name
 * @param {string} reason - Failure reason
 * @param {object} [options]
 * @param {string} [options.date] - The run date
 * @param {string} [options.commit] - Git commit hash
 */
export async function enqueueReplay(runId, job, reason, options = {}) {
  const { appendRecoveryEntry } = await import("./recovery.js");

  appendRecoveryEntry({
    runId,
    date: options.date || new Date().toISOString().slice(0, 10),
    job: job || "daily-newsletter",
    status: options.status || "FAILED",
    reason: reason || "Enqueued for automatic replay",
    commit: options.commit,
  });

  console.log(`🔁 Run ${runId} enqueued for automatic replay`);

  const result = await runReplayEngine();
  return result;
}

/**
 * Run the replay engine standalone (CLI entry point).
 */
async function main() {
  const result = await runReplayEngine();
  process.exit(result.failed > 0 ? 1 : 0);
}

// Allow standalone execution: node core/replay-engine.js
const isDirectRun = process.argv[1] && process.argv[1].endsWith("replay-engine.js");
if (isDirectRun) {
  main().catch((err) => {
    console.error(`[REPLAY-ENGINE FATAL] ${err.message}`);
    process.exit(1);
  });
}

export default {
  runReplayEngine,
  enqueueReplay,
};
