# ============================================================
# GAHWA NEWSLETTER — Hetzner VPS Environment Configuration
# ============================================================
# Copy this file to operator/.env on the Hetzner VPS
# and fill in the values.
#
#   cp /opt/gahwa-newsletter/operator/env.hetzner.template /opt/gahwa-newsletter/operator/.env
#   chmod 600 /opt/gahwa-newsletter/operator/.env
#   vi /opt/gahwa-newsletter/operator/.env
# ============================================================

# DeepSeek API Key (required — newsletter generation)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Apps Script Webhook URL (required — email dispatch)
# Deploy your Apps Script project as a Web App, then paste the URL here.
# Format: https://script.google.com/macros/s/ABC123/exec
APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/your-script-id/exec

# Webhook Secret (must match WEBHOOK_SECRET in Apps Script PropertiesService)
# Run `openssl rand -hex 24` to generate, then set in both places:
#   1. Apps Script: run storeSecrets() and paste this value
#   2. Here: paste the same hex string
WEBHOOK_SECRET=your-webhook-secret-hex-here

# GitHub Webhook Secret for HMAC-SHA256 verification (required for production)
# Used by server.js to verify incoming GitHub webhook payloads.
# Generate with: openssl rand -hex 32
# Then configure in GitHub repo Settings > Webhooks > Add webhook > Secret
GITHUB_WEBHOOK_SECRET=

# Listener port (optional, default: 3000)
# LISTENER_PORT=3000

# ── GIT CONFIGURATION ───────────────────────────────────────
# The server uses git pull to deploy code on webhook receipt.
# The repo at /opt/gahwa-newsletter must have the origin remote
# configured correctly. SSH deploy keys are set up separately
# on the server (not through GitHub Actions).
#
# To configure git on the Hetzner server:
#   cd /opt/gahwa-newsletter
#   git remote set-url origin git@github.com:your-org/gahwa-newsletter.git
#   # Then add the server's SSH key as a deploy key in GitHub
