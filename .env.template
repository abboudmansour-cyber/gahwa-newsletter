# ============================================================
# GAHWA NEWSLETTER — Root Environment Configuration
# ============================================================
# Copy this file to operator/.env and fill in the values.
#
#   cp .env.template operator/.env
#   chmod 600 operator/.env
#
# On Hetzner VPS:
#   cp /opt/gahwa-newsletter/.env.template /opt/gahwa-newsletter/operator/.env
# ============================================================

# ════════════════════════════════════════════════════════════
# REQUIRED — Content Generation
# ════════════════════════════════════════════════════════════

# DeepSeek API Key (required — newsletter generation via DeepSeek)
# Sign up at https://platform.deepseek.com to get an API key.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here


# ════════════════════════════════════════════════════════════
# REQUIRED — Delivery Layer (Apps Script Webhook)
# ════════════════════════════════════════════════════════════

# Apps Script Webhook URL (required — email dispatch)
# Deploy your Apps Script project as a Web App, then paste the URL here.
# Format: https://script.google.com/macros/s/ABC123/exec
#
# Deployment steps:
#   1. Open https://script.google.com
#   2. File → Open → Select the Gahwa project
#   3. Deploy → New Deployment → Web App
#   4. Execute as: Me
#   5. Who has access: Anyone
#   6. Copy the deployment URL and paste below
APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbz5tnAEWNrY-6dDAmMzlyiuhAC1pa6Y8vzHcLcVBitYM4hacyR3LCFcsUM_no2LnNTp/exec


# ════════════════════════════════════════════════════════════
# REQUIRED — Webhook Secret (for header-based auth)
# ════════════════════════════════════════════════════════════

# WEBHOOK_SECRET — used for Authorization: Bearer header in webhook requests.
# REQUIRED for auth. The operator will throw a fatal error at startup if this is missing.
#
# Auth model: HEADER-BASED only (no PropertiesService dependency).
#
# The secret must match the hardcoded secretToken in scripts/Code.gs.
#
# Generate with: openssl rand -hex 24
# Then set the SAME value in BOTH places:
#   1. operator/.env — WEBHOOK_SECRET=<value>
#   2. scripts/Code.gs — var secretToken = '<value>'
#
# To change the secret:
#   1. Generate new: openssl rand -hex 24
#   2. Update scripts/Code.gs secretToken
#   3. Update this value
#   4. Redeploy the Apps Script project

# WEBHOOK_SECRET=your-webhook-secret-hex-here


# ════════════════════════════════════════════════════════════
# OPTIONAL — GitHub Configuration
# ════════════════════════════════════════════════════════════

# GitHub Personal Access Token (fine-grained PAT with repo scope)
# Only needed if SSH keys are not configured.
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-token-here

# Git user name/email for commits
GIT_USER_NAME=Gahwa Operator
GIT_USER_EMAIL=operator@gahwa.ai


# ════════════════════════════════════════════════════════════
# OPTIONAL — Execution Tuning
# ════════════════════════════════════════════════════════════

# Output directory for generated newsletter JSON
# Default: output/
OUTPUT_DIR=output

# Log level: DEBUG, INFO, WARN, ERROR
# Default: INFO
LOG_LEVEL=INFO


# ════════════════════════════════════════════════════════════
# HETZNER VPS SPECIFIC (used by setup_hetzner.sh)
# ════════════════════════════════════════════════════════════

# The deploy key is automatically generated by setup_hetzner.sh
# Do NOT modify these — they are set during Hetzner setup.
HETZNER_DEPLOY_KEY_PATH=/root/.ssh/id_ed25519
HETZNER_PROJECT_PATH=/opt/gahwa-newsletter
HETZNER_CRON_SCHEDULE="0 7 * * *"
